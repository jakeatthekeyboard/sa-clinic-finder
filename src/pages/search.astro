---
import Base from '../layouts/Base.astro';
import { facilities, PROVINCES, SERVICE_MAP, provinceSlug, typeLabel } from '../data/helpers';

// Build lightweight search index (name, province, type, services, slug, url)
const searchData = facilities
  .filter(f => f.province !== '')
  .map(f => ({
    n: f.name,
    p: f.province,
    t: f.type,
    s: Object.entries(f.services).filter(([,v]) => v).map(([k]) => k),
    u: f.url_path,
    h: f.operating_hours.is_24_hour,
  }));
---
<Base
  title="Search Clinics — Clinic Finder SA"
  description="Search public clinics and hospitals across South Africa by name, province, or service. Find ARVs, maternity, TB treatment, emergency care near you."
>
  <div class="container" style="padding: 32px 0;">
    <h1 style="font-size: 1.5rem; margin-bottom: 16px;">Search Clinics</h1>

    <div style="margin-bottom: 16px;">
      <input
        type="text"
        id="q"
        placeholder="Search by clinic name..."
        style="width: 100%; padding: 12px 16px; border: 2px solid var(--border); border-radius: var(--radius); font-size: 1rem; outline: none;"
      />
    </div>

    <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px;">
      <select id="prov" style="padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9rem;">
        <option value="">All provinces</option>
        {PROVINCES.map(p => <option value={p}>{p}</option>)}
      </select>
      <select id="svc" style="padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.9rem;">
        <option value="">All services</option>
        {Object.entries(SERVICE_MAP).map(([key, s]) => <option value={key}>{s.plain}</option>)}
      </select>
      <button id="nearMe" class="btn btn--outline" style="padding: 8px 16px; font-size: 0.9rem;">
        Near me
      </button>
    </div>

    <div id="results"></div>
    <p id="count" style="font-size: 0.85rem; color: var(--text-muted); margin-top: 16px;"></p>
  </div>

  <script define:vars={{ searchData, SERVICE_MAP }}>
    const data = searchData;
    const q = document.getElementById('q');
    const prov = document.getElementById('prov');
    const svc = document.getElementById('svc');
    const results = document.getElementById('results');
    const count = document.getElementById('count');
    const nearMe = document.getElementById('nearMe');

    const typeLabels = {
      clinic: 'Clinic', district_hospital: 'District Hospital',
      community_health_centre: 'Community Health Centre',
      regional_hospital: 'Regional Hospital', tertiary_hospital: 'Tertiary Hospital',
      satellite_clinic: 'Satellite Clinic',
    };

    function render(items) {
      const show = items.slice(0, 50);
      results.innerHTML = show.map(f => `
        <a href="${f.u}" style="display:block;padding:14px 16px;border:1px solid #e0e0e0;border-radius:8px;margin-bottom:8px;text-decoration:none;color:#1a1a1a;">
          <strong>${f.n}</strong>
          <span style="font-size:0.85rem;color:#555;margin-left:8px;">${typeLabels[f.t]||f.t} · ${f.p}${f.h?' · 24h':''}</span>
          ${f._dist ? `<span style="font-size:0.8rem;color:#1a7a4c;margin-left:8px;">${f._dist.toFixed(1)} km</span>` : ''}
        </a>
      `).join('');
      count.textContent = `Showing ${show.length} of ${items.length} results`;
    }

    function filter() {
      const query = q.value.toLowerCase();
      const provVal = prov.value;
      const svcVal = svc.value;
      let filtered = data;
      if (query) filtered = filtered.filter(f => f.n.toLowerCase().includes(query));
      if (provVal) filtered = filtered.filter(f => f.p === provVal);
      if (svcVal) filtered = filtered.filter(f => f.s.includes(svcVal));
      render(filtered);
    }

    q.addEventListener('input', filter);
    prov.addEventListener('change', filter);
    svc.addEventListener('change', filter);

    nearMe.addEventListener('click', () => {
      if (!navigator.geolocation) { alert('Geolocation not supported'); return; }
      nearMe.textContent = 'Finding...';
      navigator.geolocation.getCurrentPosition(pos => {
        const lat = pos.coords.latitude, lng = pos.coords.longitude;
        const R = 6371;
        const withDist = data.map(f => {
          // Look up coordinates from full facilities data embedded in search
          return { ...f, _dist: 0 };
        });
        nearMe.textContent = 'Near me';
        // For now, just filter to user's province or show all sorted
        filter();
      }, () => {
        nearMe.textContent = 'Near me';
        alert('Could not get your location. Please allow location access.');
      });
    });

    // Initial render
    filter();
  </script>
</Base>
