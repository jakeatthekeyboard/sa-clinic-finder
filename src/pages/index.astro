---
import Base from '../layouts/Base.astro';
import { facilities, PROVINCES, SERVICE_MAP, provinceSlug } from '../data/helpers';

const totalFacilities = facilities.filter(f => f.province !== '').length;
const provinceStats = PROVINCES.map(p => ({
  name: p,
  slug: provinceSlug(p),
  count: facilities.filter(f => f.province === p).length,
}));

const faqs = [
  {
    question: 'Are public clinics in South Africa free?',
    answer: 'Yes. All primary healthcare services at public clinics are free for South African citizens and permanent residents. This includes consultations, basic medication, HIV testing, TB treatment, immunisations, family planning, and antenatal care. You do not need medical aid. Hospital visits may charge a means-tested fee, but emergency treatment is never refused.',
  },
  {
    question: 'What services do public clinics offer?',
    answer: 'Public clinics provide primary healthcare including chronic medication (blood pressure, diabetes, epilepsy), HIV testing and ARV treatment, TB screening and treatment, maternity and antenatal care, immunisations for children, family planning, dental care, mental health services, and child health (growth monitoring, nutrition support). Not every clinic offers every service — use Clinic Finder SA to check what is available at a specific facility.',
  },
  {
    question: 'Do I need an appointment to visit a public clinic?',
    answer: 'Most public clinics operate on a walk-in basis — no appointment needed. Arrive early (before 07:00 if possible) to avoid long queues. Some services like dental care and mental health counselling may require an appointment or referral. Chronic medication patients can sometimes book specific collection times through the CCMDD programme.',
  },
  {
    question: 'What are the operating hours of public clinics?',
    answer: 'Standard clinic hours are Monday to Friday, 07:00 to 16:00. Some clinics extend hours to 19:00. Community health centres and district hospitals typically offer 24-hour services including emergency care. Check the specific facility page on Clinic Finder SA to see if it is open 24 hours.',
  },
  {
    question: 'Can foreign nationals use public clinics in South Africa?',
    answer: 'Yes. Emergency medical treatment cannot be refused regardless of nationality or documentation status. Children under 6, pregnant women, and people with notifiable conditions (like TB) are entitled to free treatment. Other non-emergency services may require payment based on the hospital tariff. Bring your passport, asylum permit, or refugee status documentation.',
  },
  {
    question: 'What should I bring to a clinic visit?',
    answer: 'Bring your South African ID or passport, your green clinic card (patient-held record), and any current medication you are taking. For children under 5, bring the Road to Health booklet. If you are visiting a hospital rather than a primary clinic, you will usually need a referral letter from a clinic. Pregnant women should bring their maternity case record after the first antenatal visit.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---
<Base
  title="Clinic Finder SA — Find Your Nearest Public Clinic or Hospital"
  description={`Search ${totalFacilities} public clinics and hospitals across South Africa. Filter by province, services like ARVs, maternity, TB treatment, and get directions.`}
  jsonLd={faqJsonLd}
>
  <section style="background: var(--green); color: #fff; padding: 48px 0 40px;">
    <div class="container" style="text-align: center;">
      <h1 style="font-size: 1.8rem; margin-bottom: 8px;">Find a Public Clinic Near You</h1>
      <p style="font-size: 1.1rem; opacity: 0.9; max-width: 540px; margin: 0 auto 24px;">
        Search {totalFacilities.toLocaleString()} government clinics and hospitals across South Africa. Free. No sign-up.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; align-items: center;">
        <button id="heroNearMe" class="btn" style="background: #fff; color: var(--green); font-size: 1.05rem; padding: 14px 28px; font-weight: 700; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          List clinics near me
        </button>
        <a href="/search" class="btn btn--outline" style="border-color: #fff; color: #fff; font-size: 0.95rem; padding: 12px 22px;">
          Or browse &amp; search
        </a>
      </div>
      <p id="heroNearMeStatus" style="font-size: 0.85rem; opacity: 0.85; margin-top: 14px; min-height: 1.2em;"></p>
    </div>
  </section>

  <script is:inline>
    (function () {
      const btn = document.getElementById('heroNearMe');
      const status = document.getElementById('heroNearMeStatus');
      if (!btn) return;
      btn.addEventListener('click', function () {
        if (!navigator.geolocation) {
          status.textContent = 'Location not available on this device — taking you to search.';
          window.location.href = '/search';
          return;
        }
        const original = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = 'Finding your location…';
        status.textContent = 'Please allow location access when prompted.';
        navigator.geolocation.getCurrentPosition(function (pos) {
          try {
            sessionStorage.setItem('cf_user_loc', JSON.stringify({
              lat: pos.coords.latitude,
              lng: pos.coords.longitude,
              ts: Date.now(),
            }));
          } catch (e) {}
          window.location.href = '/search?near=1';
        }, function () {
          btn.disabled = false;
          btn.innerHTML = original;
          status.textContent = 'Could not get your location. You can still browse or enable location in your browser settings.';
        }, { enableHighAccuracy: false, timeout: 10000, maximumAge: 300000 });
      });
    })();
  </script>

  <section class="container" style="padding: 40px 0;">
    <h2 style="font-size: 1.3rem; margin-bottom: 20px;">Browse by Province</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px;">
      {provinceStats.map(p => (
        <a href={`/clinics/${p.slug}`} class="card" style="text-decoration: none; color: var(--text);">
          <strong>{p.name}</strong>
          <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 4px;">
            {p.count} facilities
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="container" style="padding: 0 0 40px;">
    <h2 style="font-size: 1.3rem; margin-bottom: 20px;">Find by Service</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      {Object.entries(SERVICE_MAP).map(([key, svc]) => (
        <a href={`/services/${svc.slug}`} class="chip" style="font-size: 0.9rem; padding: 8px 16px; text-decoration: none;">
          {svc.plain}
        </a>
      ))}
    </div>
  </section>

  <section style="background: var(--bg-alt); padding: 40px 0;">
    <div class="container">
      <h2 style="font-size: 1.3rem; margin-bottom: 24px;">Frequently Asked Questions</h2>
      <div style="max-width: 720px; display: grid; gap: 20px;">
        {faqs.map(faq => (
          <details style="border: 1px solid var(--border); border-radius: var(--radius); padding: 0;">
            <summary style="cursor: pointer; font-weight: 600; font-size: 0.95rem; padding: 16px; list-style: none; display: flex; justify-content: space-between; align-items: center;">
              {faq.question}
              <span style="font-size: 1.2rem; color: var(--text-muted); flex-shrink: 0; margin-left: 12px;">+</span>
            </summary>
            <div style="padding: 0 16px 16px; font-size: 0.9rem; color: var(--text-muted); line-height: 1.7;">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section style="padding: 40px 0;">
    <div class="container">
      <h2 style="font-size: 1.3rem; margin-bottom: 20px;">Health Guides</h2>
      <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.95rem;">Plain-language guides to getting care in the public health system.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; margin-bottom: 16px;">
        <a href="/guides/how-to-get-arvs" class="card" style="text-decoration: none; color: var(--text);">
          <strong>How to Get ARVs</strong>
          <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 4px;">Same-day initiation, what to bring, follow-up visits</div>
        </a>
        <a href="/guides/tb-treatment-what-to-expect" class="card" style="text-decoration: none; color: var(--text);">
          <strong>TB Treatment</strong>
          <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 4px;">Diagnosis, 6-month regimen, DOTS, side effects</div>
        </a>
        <a href="/guides/free-maternity-care" class="card" style="text-decoration: none; color: var(--text);">
          <strong>Free Maternity Care</strong>
          <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 4px;">Antenatal visits, delivery, postnatal care</div>
        </a>
        <a href="/guides/medical-emergency-guide" class="card" style="text-decoration: none; color: var(--text);">
          <strong>Medical Emergencies</strong>
          <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 4px;">Who to call, where to go, your rights</div>
        </a>
      </div>
      <a href="/guides" style="font-size: 0.9rem; font-weight: 600;">Browse all guides &rarr;</a>
    </div>
  </section>

  <section style="padding: 40px 0;">
    <div class="container">
      <h2 style="font-size: 1.3rem; margin-bottom: 16px;">About Clinic Finder SA</h2>
      <div style="max-width: 640px; color: var(--text-muted); font-size: 0.95rem; line-height: 1.7;">
        <p>84% of South Africans rely on the public health system. Finding the right clinic should not be hard.</p>
        <p style="margin-top: 12px;">Clinic Finder SA is a free, independent directory of public clinics and hospitals. We show you what services are available, where the facility is, and how to get there — on any phone, using minimal data.</p>
        <p style="margin-top: 12px;">We are not affiliated with any government department. Our data comes from OpenStreetMap and the Humanitarian Data Exchange, verified against official sources where possible.</p>
        <p style="margin-top: 12px;"><a href="/guide">Learn how to use this site</a> — search, browse, filter, get directions, and share on WhatsApp.</p>
      </div>
    </div>
  </section>
</Base>
