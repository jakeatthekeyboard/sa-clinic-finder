---
import Base from '../../layouts/Base.astro';
import { facilities, PROVINCES, SERVICE_MAP, SERVICE_SLUGS, provinceSlug, typeLabel } from '../../data/helpers';
import { SERVICE_EDITORIAL } from '../../data/service-editorial';

export function getStaticPaths() {
  return Object.entries(SERVICE_MAP).map(([key, svc]) => ({
    params: { service: svc.slug },
    props: { serviceKey: key, serviceName: svc.plain, serviceLabel: svc.label },
  }));
}

const { serviceKey, serviceName, serviceLabel } = Astro.props;
const editorial = SERVICE_EDITORIAL[serviceKey];
const serviceFacilities = facilities
  .filter(f => f.services[serviceKey] && f.province !== '')
  .sort((a, b) => a.province.localeCompare(b.province) || a.name.localeCompare(b.name));

const byProvince = PROVINCES.map(p => ({
  name: p,
  slug: provinceSlug(p),
  facilities: serviceFacilities.filter(f => f.province === p),
})).filter(p => p.facilities.length > 0);

const topProvinces = byProvince.slice(0, 3);

const serviceFaqs = [
  {
    q: `Where can I get ${serviceName.toLowerCase()} in South Africa?`,
    a: `${serviceFacilities.length} public clinics and hospitals across South Africa offer ${serviceName.toLowerCase()}. ${topProvinces.length > 0 ? `The provinces with the most facilities are ${topProvinces.map(p => `${p.name} (${p.facilities.length})`).join(', ')}.` : ''} All services at government facilities are free for South African citizens and permanent residents.`,
  },
  {
    q: `Is ${serviceName.toLowerCase()} free at public clinics?`,
    a: `Yes. ${serviceName} is provided free of charge at all public health facilities in South Africa. You do not need medical aid or insurance. Bring your South African ID or passport and your clinic card if you have one.`,
  },
  {
    q: `Do I need a referral for ${serviceName.toLowerCase()}?`,
    a: editorial?.eligibility
      ? `Eligibility: ${editorial.eligibility} In most cases, you can walk in to any public clinic that offers this service. District hospitals may require a referral from a primary clinic unless it is an emergency.`
      : `In most cases, you can walk in to any public clinic that offers ${serviceName.toLowerCase()}. District hospitals may require a referral from a primary health clinic unless it is an emergency.`,
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": serviceFaqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

const jsonLd = editorial ? [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: `${serviceName} at Public Clinics in South Africa`,
    description: `Find ${serviceFacilities.length} public clinics and hospitals offering ${serviceName.toLowerCase()} across South Africa.`,
    url: `https://clinicfinder.co.za/services/${SERVICE_MAP[serviceKey].slug}`,
    publisher: { '@type': 'Organization', name: 'Clinic Finder SA' },
    datePublished: '2026-04-16',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalWebPage',
    about: { '@type': 'MedicalCondition', name: serviceLabel },
    lastReviewed: '2026-04-16',
  },
] : undefined;
---
<Base
  title={`${serviceName} — Public Clinics in South Africa`}
  description={`Find ${serviceFacilities.length} public clinics and hospitals offering ${serviceName.toLowerCase()} across South Africa. Browse by province.`}
  jsonLd={jsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <div class="container" style="padding: 32px 0;">
    <nav style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 16px;">
      <a href="/">Home</a> &rsaquo; <a href="/services">Services</a> &rsaquo; {serviceName}
    </nav>
    <h1 style="font-size: 1.5rem; margin-bottom: 8px;">{serviceName}</h1>
    <p style="color: var(--text-muted); margin-bottom: 24px;">{serviceFacilities.length} public facilities across South Africa</p>

    {editorial && (
      <section style="margin-bottom: 32px; max-width: 720px;">
        <p style="line-height: 1.7; font-size: 0.95rem; color: var(--text);">{editorial.intro}</p>
        {editorial.keyFact && (
          <div style="margin-top: 16px; border-left: 4px solid var(--green); padding: 12px 16px; background: var(--green-light); border-radius: 0 var(--radius) var(--radius) 0;">
            <strong style="font-size: 0.85rem; color: var(--green-dark);">Key fact:</strong>
            <span style="font-size: 0.9rem; margin-left: 4px;">{editorial.keyFact}</span>
          </div>
        )}
      </section>
    )}

    {editorial && (
      <section style="margin-bottom: 32px; max-width: 720px;">
        <h2 style="font-size: 1.2rem; margin-bottom: 16px; color: var(--green-dark);">What to expect</h2>
        <div style="display: grid; gap: 12px;">
          {editorial.whatToExpect.map((step, i) => (
            <div style="display: flex; gap: 16px; align-items: flex-start;">
              <div style="flex-shrink: 0; width: 36px; height: 36px; background: var(--green-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--green-dark); font-size: 0.9rem;">{i + 1}</div>
              <div>
                <strong style="font-size: 0.95rem;">{step.step}</strong>
                <p style="font-size: 0.9rem; color: var(--text-muted); margin-top: 2px; line-height: 1.6;">{step.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {editorial && (
      <section style="background: var(--bg-alt); border-radius: var(--radius); padding: 20px; margin-bottom: 32px; max-width: 720px;">
        <h2 style="font-size: 1.1rem; margin-bottom: 8px; color: var(--green-dark);">Who is eligible?</h2>
        <p style="font-size: 0.9rem; line-height: 1.7;">{editorial.eligibility}</p>
      </section>
    )}

    {editorial?.guideSlug && (
      <section style="background: var(--green-light); border-radius: var(--radius); padding: 20px; margin-bottom: 32px; max-width: 720px;">
        <h2 style="font-size: 1.1rem; margin-bottom: 8px; color: var(--green-dark);">Read the full guide</h2>
        <p style="font-size: 0.9rem; margin-bottom: 12px;">
          Our guide covers everything in detail: step-by-step process, FAQs, and practical tips.
        </p>
        <a href={`/guides/${editorial.guideSlug}`} class="btn btn--primary" style="font-size: 0.9rem;">
          {editorial.guideName} &rarr;
        </a>
      </section>
    )}

    <section style="margin-bottom: 32px; max-width: 720px;">
      <h2 style="font-size: 1.15rem; margin-bottom: 16px;">Frequently Asked Questions</h2>
      {serviceFaqs.map(f => (
        <details style="border-bottom: 1px solid var(--border); padding: 12px 0;">
          <summary style="cursor: pointer; font-weight: 600; font-size: 0.95rem;">{f.q}</summary>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin-top: 8px; line-height: 1.6;">{f.a}</p>
        </details>
      ))}
    </section>

    <section style="margin-bottom: 32px;">
      <h2 style="font-size: 1.15rem; margin-bottom: 12px;">Other Health Services</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">
        {Object.entries(SERVICE_MAP).filter(([k]) => k !== serviceKey).map(([k, svc]) => (
          <a href={`/services/${svc.slug}`} style="display: inline-block; padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 0.85rem; color: var(--text); text-decoration: none; transition: border-color 0.15s;">
            {svc.plain}
          </a>
        ))}
      </div>
    </section>

    <section style="margin-bottom: 32px;">
      <h2 style="font-size: 1.15rem; margin-bottom: 12px;">Browse by Province</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">
        {PROVINCES.map(p => (
          <a href={`/clinics/${provinceSlug(p)}`} style="display: inline-block; padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 0.85rem; color: var(--text); text-decoration: none; transition: border-color 0.15s;">
            {p}
          </a>
        ))}
      </div>
    </section>

    <h2 style="font-size: 1.2rem; margin-bottom: 16px;">{serviceFacilities.length} facilities offering {serviceName.toLowerCase()}</h2>

    {byProvince.map(prov => (
      <section style="margin-bottom: 32px;">
        <h3 style="font-size: 1.1rem; margin-bottom: 12px;">
          <a href={`/clinics/${prov.slug}`}>{prov.name}</a>
          <span style="font-weight: normal; color: var(--text-muted); font-size: 0.9rem;"> ({prov.facilities.length})</span>
        </h3>
        <div style="display: grid; gap: 8px;">
          {prov.facilities.map(f => {
            const addr = [f.address.street, f.address.suburb, f.address.city].filter(Boolean).join(', ');
            return (
              <a href={f.url_path} class="card" style="text-decoration: none; color: var(--text); padding: 12px 16px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                  <div>
                    <strong>{f.name}</strong>
                    {addr && <div style="font-size: 0.85rem; color: var(--text); margin-top: 2px;">{addr}</div>}
                    <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 2px;">
                      {typeLabel(f.type)}
                      {f.district && ` · ${f.district}`}
                    </div>
                  </div>
                  {f.operating_hours.is_24_hour && <span class="chip" style="font-size: 0.75rem; background: #fef3cd; color: #856404;">24h</span>}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </div>
</Base>
