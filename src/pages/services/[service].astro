---
import Base from '../../layouts/Base.astro';
import { facilities, PROVINCES, SERVICE_MAP, SERVICE_SLUGS, provinceSlug, typeLabel } from '../../data/helpers';

export function getStaticPaths() {
  return Object.entries(SERVICE_MAP).map(([key, svc]) => ({
    params: { service: svc.slug },
    props: { serviceKey: key, serviceName: svc.plain, serviceLabel: svc.label },
  }));
}

const { serviceKey, serviceName, serviceLabel } = Astro.props;
const serviceFacilities = facilities
  .filter(f => f.services[serviceKey] && f.province !== '')
  .sort((a, b) => a.province.localeCompare(b.province) || a.name.localeCompare(b.name));

const byProvince = PROVINCES.map(p => ({
  name: p,
  slug: provinceSlug(p),
  facilities: serviceFacilities.filter(f => f.province === p),
})).filter(p => p.facilities.length > 0);
---
<Base
  title={`${serviceName} — Public Clinics in South Africa`}
  description={`Find ${serviceFacilities.length} public clinics and hospitals offering ${serviceName.toLowerCase()} across South Africa. Browse by province.`}
>
  <div class="container" style="padding: 32px 0;">
    <nav style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 16px;">
      <a href="/">Home</a> &rsaquo; <a href="/services">Services</a> &rsaquo; {serviceName}
    </nav>
    <h1 style="font-size: 1.5rem; margin-bottom: 8px;">{serviceName}</h1>
    <p style="color: var(--text-muted); margin-bottom: 24px;">{serviceFacilities.length} public facilities across South Africa</p>

    {byProvince.map(prov => (
      <section style="margin-bottom: 32px;">
        <h2 style="font-size: 1.15rem; margin-bottom: 12px;">
          <a href={`/clinics/${prov.slug}`}>{prov.name}</a>
          <span style="font-weight: normal; color: var(--text-muted); font-size: 0.9rem;"> ({prov.facilities.length})</span>
        </h2>
        <div style="display: grid; gap: 8px;">
          {prov.facilities.map(f => (
            <a href={f.url_path} class="card" style="text-decoration: none; color: var(--text); padding: 12px 16px;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                  <strong>{f.name}</strong>
                  <span style="font-size: 0.85rem; color: var(--text-muted); margin-left: 8px;">{typeLabel(f.type)}</span>
                </div>
                {f.operating_hours.is_24_hour && <span class="chip" style="font-size: 0.75rem; background: #fef3cd; color: #856404;">24h</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</Base>
